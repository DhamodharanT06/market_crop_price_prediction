{
  "version": 2,
  "functions": {
    "cropflask.py": {
      "includeFiles": "Crop_price_pred_pick.pkl"
    }
  },
  "builds": [
    {
      "src": "cropflask.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "cropflask.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
